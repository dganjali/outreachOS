# OutreachOS environment template.
#
# Copy to `.env` for local dev (`npm run server:dev` loads it). NEVER commit a
# real `.env` - it is gitignored. In production, server secrets are injected
# from Google Secret Manager (see cloudbuild.yaml --set-secrets); the VITE_*
# values are baked into the frontend bundle at build time.
#
# Values below are placeholders only - no real credentials live in this file.

# ---------------------------------------------------------------------------
# SERVER (api/ + server/) - never exposed to the browser
# ---------------------------------------------------------------------------

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net
MONGODB_DB=outreachos

# Firebase Admin (server-side JWT verification)
FIREBASE_PROJECT_ID=your-firebase-project-id
# Optional: full service-account JSON as a single line. Omit on Cloud Run to use
# the runtime service account (Application Default Credentials).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCS_BUCKET=your-bucket-name
CLOUD_TASKS_QUEUE=outreach-jobs
CLOUD_TASKS_TARGET_URL=https://your-service-url/api/agents/pipeline
CLOUD_TASKS_SERVICE_ACCOUNT=tasks-invoker@your-project.iam.gserviceaccount.com

# Vertex AI (Gemini) - auth via Application Default Credentials, no key needed
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
VERTEX_LOCATION=us-central1

# Encryption key for OAuth-token-at-rest + OAuth state (REQUIRED).
# Use a long random string, e.g. `openssl rand -base64 48`.
ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Shared secret for cron/Cloud Scheduler authentication (Bearer token).
CRON_SECRET=change-me-to-a-long-random-secret

# Google OAuth (Gmail integration)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Optional third-party enrichment providers (features degrade gracefully if unset)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5
# VOYAGE_API_KEY=
# SERPER_API_KEY=
# EMAILFINDER_API_KEY=
# MILLIONVERIFIER_API_KEY=

# Cross-account contact-diversity penalty (api/_lib/contacted.ts). Off unless BOTH
# are set: a stable salt makes the platform-wide contact tally anonymous.
# CONTACT_HEAT_ENABLED=true
# CONTACT_HEAT_SALT=generate-with-openssl-rand-hex-32

# Server port (defaults to 8080)
# PORT=8080

# ---------------------------------------------------------------------------
# FRONTEND (src/) - bundled into client JS, so these must be NON-secret.
# The Firebase web apiKey is a public project identifier (access is gated by
# Firebase Auth + security rules), NOT a credential.
# ---------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
