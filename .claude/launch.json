{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "outreachos-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "port": 5173
    },
    {
      "name": "outreachos-api",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "server:dev"
      ],
      "port": 8080
    },
    {
      "name": "harness",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "http.server",
        "8799",
        "--directory",
        "/tmp"
      ],
      "port": 8799
    }
  ]
}